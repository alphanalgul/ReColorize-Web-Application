<!DOCTYPE html>
<html lang="en">>
        <meta charset="utf-8">

        <!--Referencing Bootstrap CSS-->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" 
        integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" 
        crossorigin="anonymous">

        <!--Referencing Bootstrap JS-->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" 
        integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" 
        crossorigin="anonymous"></script>
        
        <!--Linking to the css file(separation of concerns)-->
        <link rel="stylesheet" href="/forms.css">

        <!--Title of the webpage: name of the tab-->
        <title>Sign Up</title>
    </head>
    
    <!--Adding RGB Gradient background with animation to fit the recolorization theme-->
    <body class="gradient-body">

      <div class="fade-in">

        <form id="form" action="/submit" method="post"> 

          <h1 class="h3 mb-3 fw-normal white-text">Please Sign Up</h1> 

          <div class="form-floating">
              <input type="text" class="form-control" id="floatingInput" 
              name="username" placeholder="Username" autocomplete="off"> 
              <label for="floatingInput">Username</label> 
          </div> 

          <div class="form-floating">
              <input type="password" class="form-control" id="password" placeholder="Password" name="password">
              <label for="password">Password</label>
              <div class="form-text small"></div>
         </div>

          <div class="form-floating">
              <input type="password" class="form-control" id="floatingPassword" placeholder="Confirm Password"
              name="confirmation_password" autocomplete="off"> 
              <label for="floatingPassword">Confirm Password</label> 
          </div> 

          <button class="btn gradient-button w-100 py-2" type="submit">Sign Up</button>

        <ul class="mb-0 white-text">
            <li>Username must be unique</li>
            <li>Passwords should be at least 10 characters long</li>
            <li>Passwords should contain at least 1 uppercase letter (AÔÇôZ)</li>
            <li>Passwords should contain at least 1 lowercase letter (aÔÇôz)</li>
            <li>Passwords should contain at least 1 special character (!#$%&|*+_/?~.;:'^@ÔéČÔé║)</li>
            <li>Passwords should contain at least 1 number (1234...)</li>
        </ul>

        <p class="mt-5 mb-3 white-text">┬ę Alphan Alg├╝l 2025</p> 
     </form>
<!--Displaying messages to the user--> 
   <% if (msg) { %>
  <!--For displaying flash messages such as "Registration Successful"-->   
    <% if (Array.isArray(msg) && msg.length) { %>
     <script>alert("<%= msg[0] %>");</script>
  <!--For displaying regular messages such as error-->     
    <% } else { %>
      <script>alert("<%= msg %>");</script>
    <% } %>
  <% } %>
</div>
    </body>
</html>